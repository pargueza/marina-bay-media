---
import { getEntry, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const about = await getEntry('pages', 'about');
const { Content } = about ? await render(about) : { Content: null };
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="About" description="About Marina Bay Media" />
  </head>

  <body>
    <Header />

    <main>

      <!-- ABOUT HERO -->
      <div class="w-full py-10 text-center px-6">
        <h1 class="text-2xl font-semibold mb-4">About Marina Bay Media:</h1>

        <p class="max-w-3xl mx-auto mb-4">
          Marina Bay Media was founded to help local business owners leverage the power of creative at a reasonable price.
          <br />
          We have over a decade of experience helping enterprises scale campaigns, from single operators to distributed teams.
        </p>

        <p class="max-w-3xl mx-auto font-semibold">
          We specialize in mission-critical industries such as education, financial services, food and wine, healthcare, nonprofits, political campaigns, startups, and technology.
        </p>
      </div>

      <!-- WHAT WE DO -->
      <div class="w-full py-10 text-center bg-[var(--color-teal-deep)] text-[var(--color-parchment)] px-6">
        <h2 class="text-xl mb-4">What We Do:</h2>

        <p class="max-w-4xl mx-auto text-sm leading-relaxed">
          Brand Strategy, Campaign Strategy, Canvassing, Community Outreach, Content Creation, Copywriting,
          Email Marketing, Event Marketing, Google Ads / Paid Search, Graphic Design, Local SEO,
          Performance Reporting / Analytics, Public Relations, Reputation Management, SMS Marketing,
          Social Media, Volunteer Coordination, Website Design
        </p>
      </div>

      <!-- TEAM SECTION -->
      <div class="w-full py-14 text-center px-6">

        <h2 class="text-xl mb-10">Our Team</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 max-w-5xl mx-auto">

          <!-- Nadine -->
          <div class="w-full max-w-[220px] mx-auto flex flex-col items-center text-center">
            <div class="w-40 aspect-square bg-[var(--color-washi)] rounded-lg mb-3 flex items-center justify-center">
              <!-- icon -->
            </div>
            <h3 class="text-sm font-medium">Nadine</h3>
            <p class="text-xs opacity-70">Founder</p>
          </div>

          <!-- Anna -->
          <div class="w-full max-w-[220px] mx-auto flex flex-col items-center text-center">
            <div class="w-40 aspect-square bg-[var(--color-washi)] rounded-lg mb-3 flex items-center justify-center">
              <!-- icon -->
            </div>
            <h3 class="text-sm font-medium">Anna</h3>
            <p class="text-xs opacity-70">Head of Partnerships</p>
          </div>

          <!-- San -->
          <div class="w-full max-w-[220px] mx-auto flex flex-col items-center text-center">
            <div class="w-40 aspect-square bg-[var(--color-washi)] rounded-lg mb-3 flex items-center justify-center">
              <!-- icon -->
            </div>
            <h3 class="text-sm font-medium">San</h3>
            <p class="text-xs opacity-70">Designer</p>
          </div>

        </div>
      </div>

    </main>

    <Footer />
  </body>
</html>